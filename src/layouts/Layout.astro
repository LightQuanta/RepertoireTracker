---
import { ClientRouter } from 'astro:transitions'
import ThemeToggle from '../components/ThemeToggle.vue'
import { siteConfigLoader } from '../config/config'

// TODO 解决HMR失效问题
const config = await siteConfigLoader.load();
---

<!doctype html>
<html
  lang={config.language}
  class="m-0 w-full h-full bg-[var(--el-fill-color-blank)]"
>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>{config.title}</title>

        <style is:global>
        html.darkModeSwitchAnimation::view-transition-old(root), html.darkModeSwitchAnimation::view-transition-new(root) {
            animation: none !important;
        }
        </style>

        <ClientRouter />
    </head>
    <body class="m-0 w-full h-full">
        <div class="fixed right-4 top-4 z-50">
            <ThemeToggle client:load />
        </div>
        <slot />
    </body>
</html>
